{
  "name": "dikon-example-react-simple",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "oxfmt --check \"src/**/*.{ts,tsx}\" \"*.ts\" && oxlint && tsc --noEmit --project tsconfig.json && knip --no-progress",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit --project tsconfig.json && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "fix": "oxfmt --write . && oxlint --fix",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^27.0.0",
    "knip": "^6.23.0",
    "oxfmt": "0.52.0",
    "oxlint": "^1.71.0",
    "typescript": "6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
